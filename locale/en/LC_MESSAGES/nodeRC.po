#. <b>[ Keys & Shortcuts Manual ]</b><br/> […]
msgid "manual_html"
msgstr ""
"<b>[ Keys & Shortcuts Manual ]</b><br/>\n"
"• <b>Space</b> : Open Search Menu<br/>\n"
"• <b>Delete</b> : Delete Selected Items<br/>\n"
"• <b>Ctrl+A</b> : Select All / Toggle Selection<br/>\n"
"• <b>Ctrl+G</b> : Group Selected in Frame<br/>\n"
"• <b>Ctrl+D</b> : Duplicate Selection<br/>\n"
"• <b>Ctrl+C</b> / <b>Ctrl+V</b> : Copy / Paste<br/>\n"
"• <b>Ctrl+Z</b> / <b>Ctrl+Y</b> : Undo / Redo<br/>\n"
"• <b>F</b> : Fit View / Frame Selection<br/>\n"
"• <b>G</b> : Toggle Grid Overlay<br/>\n"
"• <b>F2</b> : Rename Node / Frame Title<br/>\n"
"• <b>F11</b> : Toggle Fullscreen Mode<br/>\n"
"• <b>[</b> / <b>]</b> : Cycle UI Language (layout-independent)"

#. <h3>RealityCapture NodeRC Editor</h3> […]
msgid "controls_manual_html"
msgstr ""
"<h3>RealityCapture NodeRC Editor</h3>\n"
"<p><b>Controls:</b></p>\n"
"<ul>\n"
"  <li><b>Middle Mouse Drag / Right Mouse Drag:</b> Pan canvas.</li>\n"
"  <li><b>Mouse Wheel:</b> Zoom in / out.</li>\n"
"  <li><b>Left Click:</b> Select / drag nodes and frames.</li>\n"
"  <li><b>Space / Right Click on Empty Canvas:</b> Spawn search menu.</li>\n"
"  <li><b>Double Click Parameter Header:</b> Rename in place.</li>\n"
"</ul>\n"
"<p><b>Shortcuts:</b></p>\n"
"<ul>\n"
"  <li><b>Ctrl+G:</b> Group selected nodes in a frame.</li>\n"
"  <li><b>Ctrl+D:</b> Duplicate selected nodes.</li>\n"
"  <li><b>Ctrl+Z / Ctrl+Y:</b> Undo / Redo history.</li>\n"
"  <li><b>Delete:</b> Delete selected nodes and wires.</li>\n"
"  <li><b>F:</b> Zoom view to fit selected nodes.</li>\n"
"  <li><b>G:</b> Toggle grid visibility.</li>\n"
"  <li><b>F11:</b> Toggle fullscreen editor.</li>\n"
"  <li><b>[ / ]:</b> Cycle active UI language (layout-independent).</li>\n"
"</ul>"


